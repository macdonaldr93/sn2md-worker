# Copy to .env and fill in the values. .env is git-ignored.

# --- Required ---

# Gemini API key (Google AI Studio).
LLM_GEMINI_KEY=

# Google Drive folder ID that the Supernote syncs into.
SN2MD_WORKER__DRIVE__SOURCE_FOLDER_ID=

# Public HTTPS URL that Google Drive will POST notifications to.
# Route this through your reverse proxy to the container port.
SN2MD_WORKER__WEBHOOK__URL=

# --- linuxserver.io-style user/group ---

# On Unraid, set PUID/PGID to your `nobody:users` UID (usually 99:100) or
# to your regular host user so files land with the right ownership.
PUID=1000
PGID=1000
TZ=America/Toronto
# UMASK=022

# --- Optional overrides ---

# Container port on the host (default 8080).
# WORKER_PORT=8080

# Host paths for the volumes. Defaults are relative to this repo; on Unraid
# these typically look like /mnt/user/appdata/sn2md-worker/*.
# DATA_DIR=./data
# VAULT_DIR=./vault
# SECRETS_DIR=./secrets

# Logging level.
# SN2MD_WORKER__OBSERVABILITY__LOG_LEVEL=INFO

# Convert-queue concurrency (default 2).
# SN2MD_WORKER__QUEUE__CONVERT_CONCURRENCY=2
